{
  "rewrites": [
    { "source": "/concierge", "destination": "https://concierge.viaelite.kr" },
    { "source": "/concierge/:slug*", "destination": "https://concierge.viaelite.kr/:slug*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
